{
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "health-safety.html", "use": "@vercel/static" },
    { "src": "retail-park.html", "use": "@vercel/static" },
    { "src": "about.html", "use": "@vercel/static" },
    { "src": "media.html", "use": "@vercel/static" },
    { "src": "plots.html", "use": "@vercel/static" },
    { "src": "partners.html", "use": "@vercel/static" },
    { "src": "contact.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "settings.json", "use": "@vercel/static" },
    { "src": "video1.mp4", "use": "@vercel/static" },
    { "src": "drone-video.mp4", "use": "@vercel/static" },
    { "src": "logo.png", "use": "@vercel/static" },
    { "src": "rotated_aligned.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/about.html", "dest": "/about.html" },
    { "src": "/media.html", "dest": "/media.html" },
    { "src": "/plots.html", "dest": "/plots.html" },
    { "src": "/partners.html", "dest": "/partners.html" },
    { "src": "/contact.html", "dest": "/contact.html" },
    { "src": "/health-safety.html", "dest": "/health-safety.html" },
    { "src": "/retail-park.html", "dest": "/retail-park.html" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/settings.json", "dest": "/settings.json" },
    { "src": "/video1.mp4", "dest": "/video1.mp4" },
    { "src": "/drone-video.mp4", "dest": "/drone-video.mp4" },
    { "src": "/logo.png", "dest": "/logo.png" },
    { "src": "/rotated_aligned.png", "dest": "/rotated_aligned.png" }
  ],
  "headers": [
    {
      "source": "/drone-video.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "video/mp4" }
      ]
    }
  ]
}